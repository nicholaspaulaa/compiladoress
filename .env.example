# Copie para .env e preencha com os valores do Supabase Dashboard.
# Nunca commite o arquivo .env (ja esta no .gitignore).

# Project Settings → API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=sua-jwt-secret-do-dashboard

# Frontend (npm run dev) — copie para frontend/.env.local
# O Vite exige prefixo VITE_ (nao use SUPABASE_URL aqui)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Backend + docker compose (nao precisa de VITE_ no .env da raiz)

# E2E Playwright (copie credenciais para e2e/.env) — usuario de teste no Supabase Auth
# E2E_BASE_URL=http://localhost
# E2E_TEST_EMAIL=teste@exemplo.com
# E2E_TEST_PASSWORD=sua-senha-de-teste
#
# Timeout de execucao: padrao 10s (nao aumentar para E2E — cenario de timeout valida 10s)
# EXEC_TIMEOUT_S=10
