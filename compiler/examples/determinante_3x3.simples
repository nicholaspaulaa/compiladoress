procedimento inteiro determinante3(inteiro m[3][3])
inicio
  retorna m[0][0] * (m[1][1] * m[2][2] - m[1][2] * m[2][1])
        - m[0][1] * (m[1][0] * m[2][2] - m[1][2] * m[2][0])
        + m[0][2] * (m[1][0] * m[2][1] - m[1][1] * m[2][0]);
fim

programa demo
inteiro m[3][3], d;
inicio
  m[0][0] <- 1;
  m[0][1] <- 2;
  m[0][2] <- 3;
  m[1][0] <- 0;
  m[1][1] <- 1;
  m[1][2] <- 4;
  m[2][0] <- 5;
  m[2][1] <- 6;
  m[2][2] <- 0;

  d <- determinante3(m);
  escreval d;
fim
